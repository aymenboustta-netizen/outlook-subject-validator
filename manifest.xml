<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">

  <Id>e6b8374d-80bb-481d-81b5-3314e827fc57</Id>
  <Version>1.0.0.1</Version>
  <ProviderName>Local Test</ProviderName>
  <DefaultLocale>nl-NL</DefaultLocale>

  <DisplayName DefaultValue="Subject Validator (Local)"/>
  <Description DefaultValue="Lokale test voor subject-validatie."/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <!-- Top-level requirements dekken OnMessageSend (>= 1.10) -->
  <Requirements>
    <Sets DefaultMinVersion="1.12">
      <Set Name="Mailbox"/>
    </Sets>
  </Requirements>

  <!-- Minder rechten is beter; pas aan indien je schrijftoegang nodig hebt -->
  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
                    xsi:type="VersionOverridesV1_1">

    <!-- Aanrader: requirements ook binnen VersionOverrides specificeren -->
    <Requirements>
      <bt:Sets DefaultMinVersion="1.10">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">

        <Runtimes>
          <Runtime resid="WebViewRuntime.Url" lifetime="long">
            <Override type="javascript" resid="JSRuntime.Url"/>
          </Runtime>
        </Runtimes>

        <DesktopFormFactor>
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSendHandler"/>
            </LaunchEvents>
            <SendMode>PromptUser</SendMode>
            <SourceLocation resid="WebViewRuntime.Url"/>
          </ExtensionPoint>
        </DesktopFormFactor>

      </Host>
    </Hosts>

    <Resources>
      <bt:Urls>
        <bt:Url id="WebViewRuntime.Url"
                DefaultValue="https://aymenboustta-netizen.github.io/outlook-subject-validator/sending.html"/>
        <bt:Url id="JSRuntime.Url"
                DefaultValue="https://aymenboustta-netizen.github.io/outlook-subject-validator/sending.js"/>
      </bt:Urls>
    </Resources>

  </VersionOverrides>

</OfficeApp>
